# Environment variables
.env
.env.*
!.env.example

# OS files
.DS_Store
Thumbs.db

# Editor files
.vscode/
.idea/
*.swp
*.swo
*~

# Node modules (if any tooling is added later)
node_modules/

# Temporary files
tmp/
*.tmp
*.log

