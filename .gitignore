__pycache__/
*.py[cod]
.pytest_cache/

# Generated pipeline data — committed to gitkeep dirs only
data/raw/*.json
data/processed/*.json
data/processed/*.csv
outputs/*.json
outputs/*.csv

# Sensitive files
*.pem
*.key
credentials.json
token.json
