{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "QualifierOutput",
  "description": "Schéma de validation pour la sortie du QUALIFIER de cliniques esthétiques.",
  "type": "object",
  "required": ["nom", "score", "segment", "raisons", "priorite_contact"],
  "additionalProperties": false,
  "properties": {
    "nom": {
      "type": "string",
      "minLength": 1,
      "description": "Nom de la clinique esthétique."
    },
    "score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "description": "Score commercial de la clinique sur 100."
    },
    "segment": {
      "type": "string",
      "enum": ["HOT", "WARM", "COLD"],
      "description": "Segment commercial : HOT (≥70), WARM (40–69), COLD (<40)."
    },
    "raisons": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Liste des raisons justifiant le score et le segment."
    },
    "priorite_contact": {
      "type": "string",
      "enum": ["haute", "moyenne", "basse"],
      "description": "Priorité de prise de contact : haute (HOT), moyenne (WARM), basse (COLD)."
    }
  }
}
